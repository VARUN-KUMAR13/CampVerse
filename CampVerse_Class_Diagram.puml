@startuml CampVerse_Class_Diagram

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classFontSize 11
skinparam classBackgroundColor #F8F9FA
skinparam classBorderColor #4A90D9
skinparam classHeaderBackgroundColor #4A90D9
skinparam classFontColor #333333
skinparam classHeaderFontColor #FFFFFF
skinparam arrowColor #555555
skinparam stereotypeFontSize 10
skinparam packageBackgroundColor #FFFFFF
skinparam packageBorderColor #CCCCCC
skinparam packageFontStyle bold
skinparam packageFontSize 12
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho

title <b>CampVerse — UML Class Diagram</b>\nCampus Management System

' ══════════════════════════════════════
'  USERS
' ══════════════════════════════════════
package "Users" #EBF5FB {

  class User {
    + uid : String
    + name : String
    + email : String
    + collegeId : String
    + role : String
    + degree : String
    + year : String
    + branch : String
    + section : String
    + isActive : Boolean
    --
    + updateLastLogin()
  }

  class Admin {
    + permissions : Object
  }

  class Student {
    + rollNumber : String
    + semester : String
    + academicBatch : String
    + cgpa : String
  }

  class Faculty {
    + designation : String
    + department : String
    + availability : String
  }

  User <|-- Admin
  User <|-- Student
  User <|-- Faculty
}

' ══════════════════════════════════════
'  COURSES & SCHEDULES
' ══════════════════════════════════════
package "Courses & Schedules" #EBF5FB {

  class Course {
    + courseCode : String
    + courseName : String
    + department : String
    + year : String
    + semester : String
    + classType : String
    + credits : Number
    + facultyId : String
    + status : String
  }

  class Schedule {
    + scheduleType : String
    + year : String
    + branch : String
    + section : String
    + semester : String
  }

  class Slot {
    + slotNumber : Number
    + courseCode : String
    + subjectName : String
    + startTime : String
    + endTime : String
    + room : String
    + classType : String
  }

  Schedule *-- "1..*" Slot : contains
}

' ══════════════════════════════════════
'  ATTENDANCE
' ══════════════════════════════════════
package "Attendance" #FEF9E7 {

  class AttendanceRecord <<Attendance>> {
    + courseCode : String
    + date : String
    + year : String
    + branch : String
    + section : String
    + facultyId : String
  }

  class StudentRecord {
    + studentId : String
    + status : String
  }

  AttendanceRecord *-- "1..*" StudentRecord : tracks
}

' ══════════════════════════════════════
'  ASSIGNMENTS & RESULTS
' ══════════════════════════════════════
package "Assignments & Results" #F5EEF8 {

  class Assignment {
    + title : String
    + courseCode : String
    + dueDate : Date
    + createdBy : String
    + year : String
    + semester : String
    + maxMarks : Number
    + status : String
    --
    + isOverdue()
  }

  class Submission {
    + studentId : String
    + studentName : String
    + fileName : String
    + submittedAt : Date
    + grade : Number
    + feedback : String
  }

  class GradeSheet {
    + courseCode : String
    + subjectName : String
    + year : String
    + branch : String
    + section : String
    + semester : String
    + facultyId : String
    + status : String
    + publishedAt : Date
  }

  class StudentGrade {
    + studentId : String
    + mid1 : Number
    + mid2 : Number
    + external : Number
    + totalMarks : Number
    + grade : String
    + gradePoints : Number
  }

  Assignment *-- "0..*" Submission : has
  GradeSheet *-- "1..*" StudentGrade : contains
}

' ══════════════════════════════════════
'  ANNOUNCEMENTS & NOTIFICATIONS
' ══════════════════════════════════════
package "Announcements & Notifications" #FDEDEC {

  class Announcement {
    + title : String
    + message : String
    + priority : String
    + audience : String
    + createdBy : String
    + expiryDate : Date
    --
    + isVisible()
  }

  class Notification {
    + title : String
    + message : String
    + category : String
    + targetAudience : String
    + postedBy : String
    + isRead : Boolean
  }
}

' ══════════════════════════════════════
'  EVENTS & CLUBS
' ══════════════════════════════════════
package "Events & Clubs" #E8F8F5 {

  class Event {
    + event_id : String
    + title : String
    + category : String
    + date : Date
    + venue : String
    + organizer : String
    + maxParticipants : Number
    + status : String
    --
    + isRegistrationOpen()
  }

  class Club {
    + club_id : String
    + name : String
    + category : String
    + president : String
    + faculty_advisor : String
    + memberCount : Number
    + recruitmentStatus : String
    + status : String
    --
    + isRecruitmentOpen()
  }
}

' ══════════════════════════════════════
'  PLACEMENT
' ══════════════════════════════════════
package "Placement" #FEF5E7 {

  class PlacementJob {
    + job_id : String
    + title : String
    + company : String
    + type : String
    + ctc : String
    + deadline : Date
    + eligibility : String[]
    + status : String
    + appliedCount : Number
    --
    + canUserApply()
    + getActiveJobs()
  }

  class JobApplication {
    + jobId : ObjectId
    + studentId : ObjectId
    + status : String
    + appliedDate : Date
    + documents : Doc[]
    + interviewSlots : Slot[]
    + offerDetails : Object
    --
    + apply()
    + withdraw()
    + makeOffer()
  }

  PlacementJob "1" --> "0..*" JobApplication : receives
}

' ══════════════════════════════════════
'  FEES & PAYMENTS
' ══════════════════════════════════════
package "Fees & Payments" #F9EBEA {

  class Payment {
    + orderId : String
    + paymentId : String
    + studentId : String
    + amount : Number
    + currency : String
    + feeType : String
    + academicYear : String
    + status : String
    + receipt : String
  }
}

' ══════════════════════════════════════
'  EXAMS & CALENDAR
' ══════════════════════════════════════
package "Exams & Calendar" #EAFAF1 {

  class Exam {
    + exam_id : String
    + title : String
    + course : String
    + examType : String
    + date : Date
    + venue : String
    + maxMarks : Number
    + status : String
  }

  class AcademicCalendar {
    + semester : String
    + degree : String
    + year : String
    + title : String
    + type : String
    + startDate : Date
    + endDate : Date
  }
}

' ══════════════════════════════════════
'  RELATIONSHIPS (cross-package)
' ══════════════════════════════════════
Faculty "1" --> "0..*" Course : teaches
Student "0..*" --> "0..*" Course : enrolls
Faculty "1" --> "0..*" AttendanceRecord : marks
Faculty "1" --> "0..*" Assignment : creates
Student "1" --> "0..*" Submission : submits
Faculty "1" --> "0..*" GradeSheet : manages
Admin "1" --> "0..*" Announcement : publishes
User "1" --> "0..*" Notification : receives
Student "0..*" --> "0..*" Event : registers
Student "0..*" --> "0..*" Club : joins
Admin "1" --> "0..*" PlacementJob : posts
Student "1" --> "0..*" JobApplication : applies
Student "1" --> "0..*" Payment : makes
Admin "1" --> "0..*" Exam : schedules
Admin "1" --> "0..*" AcademicCalendar : configures

@enduml
